<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Add Kitchen Report -->
    <report
        id="action_report_pos_kitchen"
        model="pos.order"
        string="Comanda Cocina"
        report_type="qweb-pdf"
        name="pos_kitchen_ticket.report_kitchen"
        print_report_name="'Cocina - %s' % (object.name)"
        attachment_use="False"
    />
    
    <template id="report_kitchen">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-family: monospace; width: 280px;">
                    <h2 style="text-align: center;">COMANDA DE COCINA</h2>
                    <hr/>
                    <div>Orden: <t t-esc="o.name"/></div>
                    <div>Fecha: <t t-esc="o.date_order"/></div>
                    <div>Total: Q <t t-esc="o.amount_total"/></div>
                    <hr/>
                    <h3>PRODUCTOS:</h3>
                    <t t-foreach="o.lines" t-as="line">
                        <div><t t-esc="int(line.qty)"/> x <t t-esc="line.product_id.name"/></div>
                    </t>
                    <hr/>
                    <center><b>PREPARAR INMEDIATAMENTE</b></center>
                </div>
            </t>
        </t>
    </template>
</odoo>
