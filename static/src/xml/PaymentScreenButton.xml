<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_kitchen_ticket.PaymentScreenButton" t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-buttons')]" position="inside">
            <button class="button kitchen-ticket-button" t-on-click="printKitchenTicket">
                <i class="fa fa-cutlery" /> Comanda Cocina
            </button>
        </xpath>
    </t>
</templates>
