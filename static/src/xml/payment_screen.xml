<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_kitchen_ticket.PaymentScreen" t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-buttons')]" position="inside">
            <button class="button btn btn-secondary kitchen-print-button" 
                    t-on-click="onClickPrintKitchen">
                <i class="fa fa-cutlery" aria-hidden="true"/> Imprimir Comanda
            </button>
        </xpath>
    </t>
</templates>
